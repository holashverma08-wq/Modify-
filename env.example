# Telegram Bot Configuration
BOT_TOKEN=1234567890:ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghij
ENVIRONMENT=production
LOG_LEVEL=INFO

# Application Security
# Comma-separated list of Telegram User IDs for initial Super Admins
ADMIN_IDS=123456789,987654321
RATE_LIMIT_MESSAGES_PER_SECOND=3

# MongoDB Atlas Configuration
MONGO_URI=mongodb+srv://username:password@cluster0.mongodb.net/?retryWrites=true&w=majority&appName=PrepGalaxy
MONGO_DB_NAME=prepgalaxy
